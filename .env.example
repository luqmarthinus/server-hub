# ----------------------------------------------------------------------------
# FastAPI Application - Environment Variables Template
# ----------------------------------------------------------------------------
ENVIRONMENT=development
JWT_SECRET=changeme_generate_random_32_byte_hex
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=mysql+aiomysql://fastapi_user:changeme_user_pass@localhost:3306/fastapi_app

MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=fastapi_app
MYSQL_USER=fastapi_user
MYSQL_PASSWORD=changeme_user_pass
MYSQL_HOST=mysql
MYSQL_PORT=3306

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
EMAIL_FROM=noreply@fastapi-app.local
EMAIL_VERIFICATION_SUBJECT="Verify your email address"
EMAIL_VERIFICATION_TEMPLATE=verification.html

LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:8000,http://localhost:3000

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIRECTORY=./uploads
