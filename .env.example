# ------------------------------------------------------------------------------
# Application Environment
# ------------------------------------------------------------------------------

ENVIRONMENT=development
#TZ=Africa/Johannesburg
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# JWT Configuration
# ------------------------------------------------------------------------------

# Generate with:
# openssl rand -hex 32

JWT_SECRET=REPLACE_WITH_SECURE_64_CHAR_HEX
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------

MYSQL_HOST=mysql
MYSQL_PORT=3306

MYSQL_DATABASE=server_hub_db

MYSQL_USER=server_hub_app
MYSQL_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

DATABASE_URL=mysql+aiomysql://server_hub_app:REPLACE_WITH_STRONG_PASSWORD@mysql:3306/server_hub_db

# ------------------------------------------------------------------------------
# CORS Configuration
# ------------------------------------------------------------------------------

CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ------------------------------------------------------------------------------
# Slack Alerting
# ------------------------------------------------------------------------------

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/WEBHOOK

ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=90
ALERT_DISK_THRESHOLD=90