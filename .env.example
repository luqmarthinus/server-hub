
ENVIRONMENT=development
JWT_SECRET=changeme_generate_random_32_byte_hex
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Timezone (defaults to UTC if not set)
# TZ=Africa/Johannesburg

# MySQL configuration
MYSQL_HOST=mysql
MYSQL_ROOT_PASSWORD=root_secure_password_placeholder
MYSQL_DATABASE=server_hub_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_user_password_placeholder
DATABASE_URL=mysql+aiomysql://app_user:app_user_password_placeholder@mysql:3306/server_hub_db

LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:8000,http://localhost:3000


# Slack alerts (replace with your own webhook)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=90
ALERT_DISK_THRESHOLD=90